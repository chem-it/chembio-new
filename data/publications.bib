@ARTICLE{Scheeff2024-mg,
  title     = "Practical access to trisubstituted {Morita‐Baylis‐Hillman‐type}
               products through copper‐catalyzed reductive aldol reactions of
               alkynones",
  author    = "Scheeff, Stephan and Chiu, Pauline",
  abstract  = "AbstractWe report a convenient and diastereoselective
               copper‐catalyzed reductive alkynone aldol addition to aldehydes,
               with pinacolborane as stoichiometric reductant, that results in
               the generation of densely functionalized, trisubstituted
               (Z)‐enone products analogous to Morita‐Baylis‐Hillman adducts.
