@article{Scheeff2019-gp,
 abstract = {A partial bioinspired as well as the total synthesis of
archazolid F, a highly potent V-ATPase inhibitory,
antiproliferative polyketide macrolide, is described. Key
features of the synthetic routes include a highly
stereoselective aldol condensation of two elaborate fragments
and macrocyclizations either by a Shiina macrolactonization or
by a challenging RCM reaction of an octaene substrate. The
syntheses unequivocally confirm the full architecture of this
very scarce archazolid.},
 author = {Scheeff, Stephan and Menche, Dirk},
 journal = {Org. Lett.},
 language = {en},
 month = {January},
 number = {1},
 pages = {271--274},
 publisher = {American Chemical Society (ACS)},
 title = {Total synthesis of archazolid F},
 volume = {21},
 year = {2019}
}
